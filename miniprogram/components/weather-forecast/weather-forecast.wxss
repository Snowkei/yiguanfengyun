.forecast-list {
  display: flex;
  flex-direction: column;
}

.forecast-item {
  display: grid;
  grid-template-columns: 120rpx 60rpx 120rpx 1fr 140rpx;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.forecast-item:last-child {
  border-bottom: none;
}

.forecast-item.today {
  font-weight: 600;
}

.day-name {
  font-size: 26rpx;
  color: #666;
}

.forecast-item.today .day-name {
  color: #667eea;
}

.weather-icon {
  font-size: 32rpx;
  text-align: center;
}

.weather-text {
  font-size: 24rpx;
  color: #888;
  text-align: center;
}

.temp-range {
  display: flex;
  align-items: center;
  padding: 0 10rpx;
}

.temp-bar {
  position: relative;
  width: 100%;
  height: 6rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 3rpx;
}

.temp-bar-fill {
  position: absolute;
  top: 0;
  height: 100%;
  border-radius: 3rpx;
  min-width: 20%;
}

.temp-dot {
  position: absolute;
  top: -8rpx;
  font-size: 22rpx;
  color: #999;
}

.temp-low {
  left: 0;
  transform: translateX(-100%);
}

.temp-high {
  right: 0;
  transform: translateX(100%);
}

.wind-info {
  text-align: right;
  color: #bbb;
}
