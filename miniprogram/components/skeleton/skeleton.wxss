.skeleton-container {
  padding: 0 24rpx;
}

.skeleton-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.skeleton-city {
  width: 200rpx;
  height: 44rpx;
  margin-bottom: 20rpx;
}

.skeleton-temp {
  width: 280rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.skeleton-desc {
  width: 160rpx;
  height: 36rpx;
}

.skeleton-card {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.skeleton-title {
  width: 120rpx;
  height: 32rpx;
  margin-bottom: 20rpx;
}

.skeleton-row {
  display: flex;
  justify-content: space-between;
}

.skeleton-item {
  width: 130rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
}

.skeleton-line {
  width: 100%;
  height: 36rpx;
  margin-bottom: 16rpx;
}
