.indices-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.index-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.index-item:active {
  transform: scale(0.95);
  background: rgba(102, 126, 234, 0.06);
}

.index-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.index-name {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.index-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.index-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.detail-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
