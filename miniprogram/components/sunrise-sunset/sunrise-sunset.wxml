<!-- 日出日落与天气详情 -->
<view class="glass-card">
  <view class="card-title">
    <text class="icon">🌅</text>
    <text>天气详情</text>
  </view>
  <view class="detail-grid">
    <view class="detail-item">
      <view class="detail-icon">🌡️</view>
      <view class="detail-info">
        <view class="detail-label">体感温度</view>
        <view class="detail-value">{{feelsLike || '--'}}°</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">💧</view>
      <view class="detail-info">
        <view class="detail-label">相对湿度</view>
        <view class="detail-value">{{humidity || '--'}}%</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">💨</view>
      <view class="detail-info">
        <view class="detail-label">风向风力</view>
        <view class="detail-value">{{windDir || '--'}}</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">👁️</view>
      <view class="detail-info">
        <view class="detail-label">能见度</view>
        <view class="detail-value">{{visibility || '--'}} km</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">☀️</view>
      <view class="detail-info">
        <view class="detail-label">紫外线</view>
        <view class="detail-value">{{uvIndex || '--'}}</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">🌅</view>
      <view class="detail-info">
        <view class="detail-label">日出日落</view>
        <view class="detail-value">{{sunrise || '06:00'}} / {{sunset || '18:00'}}</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">📊</view>
      <view class="detail-info">
        <view class="detail-label">气压</view>
        <view class="detail-value">{{pressure || '--'}} hPa</view>
      </view>
    </view>
    <view class="detail-item">
      <view class="detail-icon">🌊</view>
      <view class="detail-info">
        <view class="detail-label">降水概率</view>
        <view class="detail-value">{{rainChance || '--'}}%</view>
      </view>
    </view>
  </view>
</view>
