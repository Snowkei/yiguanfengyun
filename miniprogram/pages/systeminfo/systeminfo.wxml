<!-- 系统信息 -->
<view class="sys-page">
  <view class="sys-content">
    <view class="sys-card">
      <block wx:for="{{infoList}}" wx:key="key">
        <view class="sys-item">
          <text class="sys-label">{{item.name}}</text>
          <text class="sys-value">{{systemInfo[item.key] || '--'}}{{item.unit || ''}}</text>
        </view>
      </block>
    </view>
  </view>
</view>
