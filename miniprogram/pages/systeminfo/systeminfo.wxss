.sys-page {
  min-height: 100vh;
  background: #f0f4f8;
}

.sys-content {
  padding: 20rpx 24rpx;
  padding-top: env(safe-area-inset-top);
}

.sys-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.sys-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.sys-item:last-child {
  border-bottom: none;
}

.sys-label {
  font-size: 28rpx;
  color: #666;
}

.sys-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
