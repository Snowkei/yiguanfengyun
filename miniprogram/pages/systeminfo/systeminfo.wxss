.sys-page {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.nav-content {
  height: 88rpx; display: flex; align-items: center; padding: 0 24rpx;
  box-sizing: border-box;
}
.nav-back {
  width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; margin-left: -8rpx;
}
.nav-back-icon { font-size: 48rpx; color: #333; font-weight: 300; line-height: 1; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; color: #333; }
.nav-placeholder { width: 64rpx; }

.sys-content {
  padding: 20rpx 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 188rpx + 20rpx);
}

.sys-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.sys-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.sys-item:last-child {
  border-bottom: none;
}

.sys-label {
  font-size: 28rpx;
  color: #666;
}

.sys-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
