<!-- 关于页 -->
<view class="about-page">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-content">
      <view class="nav-back" catchtap="goBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <view class="nav-title">关于</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="about-content">

    <!-- 头部 -->
    <view class="hero">
      <view class="app-icon">🌤️</view>
      <view class="app-name">易观风云</view>
      <view class="app-desc">好看又好用的天气小程序</view>
      <view class="app-version">v{{version}}</view>
    </view>

    <!-- 功能介绍 -->
    <view class="about-group">
      <view class="group-title">功能特性</view>
      <view class="feature-list">
        <view class="feature-item">
          <text class="feature-icon">🌡️</text>
          <text>实时天气与精准预报</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🕐</text>
          <text>24小时逐时预报</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🌬️</text>
          <text>空气质量指数监控</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">💡</text>
          <text>智能生活指数建议</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🎨</text>
          <text>动态天气主题背景</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">📍</text>
          <text>全国城市天气查询</text>
        </view>
      </view>
    </view>

    <!-- 开源信息 -->
    <view class="about-group">
      <view class="group-title">开源与反馈</view>
      <view class="link-item" catchtap="copy" data-content="{{projectAddress}}">
        <text class="link-icon">📦</text>
        <view class="link-info">
          <text class="link-title">项目地址</text>
          <text class="link-url">{{projectAddress}}</text>
        </view>
        <text class="link-action">复制</text>
      </view>
      <view class="link-item" catchtap="copy" data-content="{{github}}">
        <text class="link-icon">🐱</text>
        <view class="link-info">
          <text class="link-title">GitHub</text>
          <text class="link-url">{{github}}</text>
        </view>
        <text class="link-action">复制</text>
      </view>
      <button class="share-btn" open-type="contact">
        <text class="link-icon">💬</text>
        <view class="link-info">
          <text class="link-title">微信客服</text>
          <text class="link-desc">问题反馈与建议</text>
        </view>
        <text class="link-action">联系</text>
      </button>
    </view>

    <!-- 鸣谢 -->
    <view class="about-group">
      <view class="group-title">鸣谢</view>
      <view class="thanks-item">
        <text>🗺️ 地理编码：Open-Meteo</text>
      </view>
      <view class="thanks-item">
        <text>🌤️ 天气数据：Open-Meteo</text>
      </view>
      <view class="thanks-item">
        <text>🌬️ 空气质量：WAQI</text>
      </view>
    </view>

    <!-- 底部 -->
    <view class="footer">
      <text>易观风云 · v{{version}}</text>
      <text class="footer-sub">用心感受每一天的天气</text>
    </view>

  </view>
</view>
