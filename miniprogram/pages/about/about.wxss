.about-page {
  min-height: 100vh;
  background: #f0f4f8;
}

.about-content {
  padding: 20rpx 24rpx;
  padding-top: env(safe-area-inset-top);
}

/* 头部 */
.hero {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.app-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.app-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.app-version {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 分组 */
.about-group {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  padding: 24rpx 28rpx 12rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 功能列表 */
.feature-list {
  padding: 0 28rpx 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.feature-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

/* 链接 */
.link-item, .share-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: transparent;
  border-radius: 0;
  margin: 0;
  line-height: 1.5;
  font-size: 28rpx;
}

.link-item:last-child, .share-btn:last-child {
  border-bottom: none;
}

.share-btn::after {
  border: none;
}

.link-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.link-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.link-title {
  font-size: 28rpx;
  color: #333;
}

.link-url {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.link-desc {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.link-action {
  font-size: 24rpx;
  color: #667eea;
}

/* 鸣谢 */
.thanks-item {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.thanks-item:last-child {
  border-bottom: none;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
}

.footer text {
  font-size: 24rpx;
  color: #ccc;
}

.footer-sub {
  font-size: 22rpx;
  margin-top: 8rpx;
}
