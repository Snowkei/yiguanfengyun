<!-- 设置页 -->
<view class="setting-page">
  <view class="setting-content">

    <!-- 显示设置 -->
    <view class="setting-group">
      <view class="group-title">显示设置</view>
      <view class="setting-item">
        <view class="item-label">
          <text>顶部搜索栏</text>
          <text class="item-desc">显示城市搜索入口</text>
        </view>
        <switch color="#667eea" checked="{{!setting.hiddenSearch}}" bindchange="switchChange" data-switchparam="hiddenSearch" />
      </view>
      <view class="setting-item">
        <view class="item-label">
          <text>生活指数</text>
          <text class="item-desc">显示穿衣、运动等指数</text>
        </view>
        <switch color="#667eea" checked="{{!setting.hiddenIndex}}" bindchange="switchChange" data-switchparam="hiddenIndex" />
      </view>
    </view>

    <!-- 更新设置 -->
    <view class="setting-group">
      <view class="group-title">更新与版本</view>
      <view class="setting-item">
        <view class="item-label">
          <text>新版本提醒</text>
          <text class="item-desc" wx:if="{{enableUpdate}}">有新版本时自动提醒</text>
          <text class="item-desc" wx:else>基础库版本需高于 1.9.90，当前: {{SDKVersion}}</text>
        </view>
        <switch color="#667eea" checked="{{setting.forceUpdate}}" bindchange="switchChange" data-switchparam="forceUpdate" />
      </view>
    </view>

    <!-- 小工具 -->
    <view class="setting-group">
      <view class="group-title">小工具</view>
      <view class="setting-item" catchtap="checkNFC">
        <view class="item-label">
          <text>NFC 检测</text>
          <text class="item-desc">检测设备是否支持 NFC</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item">
        <view class="item-label">
          <text>屏幕亮度</text>
          <text class="item-desc">当前：{{screenBrightness}}%</text>
        </view>
      </view>
      <view class="brightness-slider">
        <slider value="{{screenBrightness}}" min="0" max="100" block-size="14" activeColor="#667eea" bindchange="onBrightnessChange" />
      </view>
      <view class="setting-item">
        <view class="item-label">
          <text>保持常亮</text>
          <text class="item-desc">仅在当前会话生效</text>
        </view>
        <switch color="#667eea" checked="{{keepscreenon}}" bindchange="switchChange" data-switchparam="keepscreenon" />
      </view>
      <view class="setting-item" catchtap="goSystemInfo">
        <view class="item-label">
          <text>系统信息</text>
          <text class="item-desc">查看设备详细信息</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 数据管理 -->
    <view class="setting-group">
      <view class="group-title">数据管理</view>
      <view class="setting-item" catchtap="resetMenu">
        <view class="item-label">
          <text>悬浮球复位</text>
          <text class="item-desc">恢复悬浮菜单位置</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item danger" catchtap="resetSetting">
        <view class="item-label">
          <text>恢复默认设置</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="setting-item danger" catchtap="clearAll">
        <view class="item-label">
          <text>清除所有数据</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

  </view>
</view>
