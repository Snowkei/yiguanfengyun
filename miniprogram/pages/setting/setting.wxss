.setting-page {
  min-height: 100vh;
  background: #f0f4f8;
}

.setting-content {
  padding: 20rpx 24rpx;
  padding-top: env(safe-area-inset-top);
}

/* 分组 */
.setting-group {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  padding: 24rpx 28rpx 12rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #f8f8f8;
}

.setting-item.danger:active {
  background: #fff5f5;
}

.item-label {
  display: flex;
  flex-direction: column;
}

.item-label text:first-child {
  font-size: 28rpx;
  color: #333;
}

.item-desc {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.arrow {
  font-size: 36rpx;
  color: #ddd;
  font-weight: 300;
}

.danger .item-label text:first-child {
  color: #ff4757;
}

/* 亮度滑块 */
.brightness-slider {
  padding: 0 28rpx 16rpx;
}
