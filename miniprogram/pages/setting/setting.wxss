.setting-page {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.nav-content {
  height: 88rpx; display: flex; align-items: center; padding: 0 24rpx;
  box-sizing: border-box;
}
.nav-back {
  width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; margin-left: -8rpx;
}
.nav-back-icon { font-size: 48rpx; color: #333; font-weight: 300; line-height: 1; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; color: #333; }
.nav-placeholder { width: 64rpx; }

.setting-content {
  padding: 20rpx 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 188rpx + 20rpx);
}

/* 分组 */
.setting-group {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  padding: 24rpx 28rpx 12rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #f8f8f8;
}

.setting-item.danger:active {
  background: #fff5f5;
}

.item-label {
  display: flex;
  flex-direction: column;
}

.item-label text:first-child {
  font-size: 28rpx;
  color: #333;
}

.item-desc {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.arrow {
  font-size: 36rpx;
  color: #ddd;
  font-weight: 300;
}

.danger .item-label text:first-child {
  color: #ff4757;
}

/* 亮度滑块 */
.brightness-slider {
  padding: 0 28rpx 16rpx;
}
