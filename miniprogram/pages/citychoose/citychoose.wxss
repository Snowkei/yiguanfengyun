.page {
  min-height: 100vh;
  background: #f0f4f8;
}

.wrapper {
  padding-top: env(safe-area-inset-top);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-inner input {
  flex: 1;
  font-size: 26rpx;
}

.ph {
  color: #ccc;
}

.cancel-btn {
  font-size: 28rpx;
  color: #667eea;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 热门城市 */
.hot-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 20rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  padding: 14rpx 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  transition: all 0.2s;
}

.hot-item-active {
  background: #667eea;
  color: #fff;
}

/* 城市列表 */
.city-list {
  background: #fff;
  margin-top: 16rpx;
}

.letter-header {
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  position: sticky;
  top: 0;
}

.city-item {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
  transition: background 0.2s;
}

.city-item:last-child {
  border-bottom: none;
}

.city-item-active {
  background: #f0f0ff;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #ccc;
}

.empty text:first-child {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
}
