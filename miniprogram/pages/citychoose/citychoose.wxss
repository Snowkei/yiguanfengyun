.page {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.nav-content {
  height: 88rpx; display: flex; align-items: center; padding: 0 24rpx;
  box-sizing: border-box;
}
.nav-back {
  width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; margin-left: -8rpx;
}
.nav-back-icon { font-size: 48rpx; color: #333; font-weight: 300; line-height: 1; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 600; color: #333; }
.nav-placeholder { width: 64rpx; }

/* 占位：与 fixed 导航栏等高 */
.nav-bar-placeholder {
  width: 100%;
}

.wrapper {
  padding-top: 0;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  padding: 0 24rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-inner input {
  flex: 1;
  font-size: 26rpx;
}

.ph {
  color: #ccc;
}

.cancel-btn {
  font-size: 28rpx;
  color: #667eea;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 热门城市 */
.hot-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 20rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  padding: 14rpx 32rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  transition: all 0.2s;
}

.hot-item-active {
  background: #667eea;
  color: #fff;
}

/* 城市列表 */
.city-list {
  background: #fff;
  margin-top: 16rpx;
}

.letter-header {
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  position: sticky;
  top: 0;
}

.city-item {
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
  transition: background 0.2s;
}

.city-item:last-child {
  border-bottom: none;
}

.city-item-active {
  background: #f0f0ff;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #ccc;
}

.empty text:first-child {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
}
