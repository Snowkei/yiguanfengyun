/* 易观风云 - 主页样式 v2.1 */
.page { position: relative; min-height: 100vh; }

/* 背景 */
.page-bg { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 0; }

/* ===== 天气动画效果 ===== */
.weather-effects { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; pointer-events: none; overflow: hidden; }

/* 雨滴 */
.rain-drop {
  position: absolute; top: -20rpx; left: var(--left); width: 2rpx; height: 40rpx;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.4));
  border-radius: 2rpx; animation: rain-fall var(--dur) linear infinite; animation-delay: var(--delay);
}
.effect-heavy-rain .rain-drop { height: 60rpx; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.55)); }
@keyframes rain-fall {
  0% { transform: translateY(-40rpx); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(100vh); opacity: 0; }
}

/* 雪花 */
.snowflake {
  position: absolute; top: -20rpx; left: var(--left); width: var(--size); height: var(--size);
  background: #fff; border-radius: 50%; opacity: 0.8;
  animation: snow-fall var(--dur) linear infinite; animation-delay: var(--delay);
  box-shadow: 0 0 6px rgba(255,255,255,0.5);
}
@keyframes snow-fall {
  0% { transform: translateY(-20rpx) translateX(0) rotate(0deg); opacity: 0; }
  10% { opacity: 0.8; }
  50% { transform: translateY(50vh) translateX(30rpx) rotate(180deg); }
  90% { opacity: 0.6; }
  100% { transform: translateY(100vh) translateX(-20rpx) rotate(360deg); opacity: 0; }
}

/* 雾 */
.fog-layer { position: absolute; width: 200%; height: 100%; opacity: 0.3; }
.fog-1 { top: 20%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent); animation: fog-drift 12s ease-in-out infinite; }
.fog-2 { top: 45%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent); animation: fog-drift 16s ease-in-out infinite reverse; }
.fog-3 { top: 70%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent); animation: fog-drift 14s ease-in-out infinite 3s; }
@keyframes fog-drift {
  0% { transform: translateX(-50%); }
  50% { transform: translateX(0%); }
  100% { transform: translateX(-50%); }
}

/* 闪电 */
.lightning-flash {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.15); animation: lightning 4s ease-in-out infinite;
}
@keyframes lightning {
  0%, 92%, 94%, 96%, 100% { opacity: 0; }
  93% { opacity: 1; }
  95% { opacity: 0.5; }
}

/* ===== 日出日落弧线 ===== */
.sun-arc-wrap { display: flex; justify-content: center; padding: 16rpx 0 8rpx; }
.sun-arc { position: relative; width: 500rpx; height: 260rpx; }

/* 弧线路径（背景） */
.sun-arc-path {
  position: absolute; bottom: 40rpx; left: 0; width: 100%; height: 200rpx;
  border: 3rpx solid rgba(0,0,0,0.06); border-bottom: none;
  border-radius: 250rpx 250rpx 0 0; box-sizing: border-box;
}
/* 弧线填充（进度） */
.sun-arc-fill {
  position: absolute; bottom: 40rpx; left: 0; width: 100%; height: 200rpx;
  border: 3rpx solid #ffa726; border-bottom: none;
  border-radius: 250rpx 250rpx 0 0; box-sizing: border-box;
  transition: clip-path 0.5s ease;
}
/* 地平线 */
.sun-horizon {
  position: absolute; bottom: 38rpx; left: -10rpx; right: -10rpx; height: 2rpx;
  background: linear-gradient(90deg, rgba(0,0,0,0.04), rgba(0,0,0,0.1), rgba(0,0,0,0.04));
}
/* 太阳点 */
.sun-arc-dot {
  position: absolute; z-index: 2; transition: all 0.5s ease;
  width: 56rpx; height: 56rpx; margin-left: -28rpx; margin-bottom: -28rpx;
}
.sun-dot-icon {
  font-size: 56rpx; filter: drop-shadow(0 0 12px rgba(255,167,38,0.6));
  display: block;
}
/* 标签 */
.sun-label-left, .sun-label-right {
  position: absolute; bottom: 0; display: flex; flex-direction: column; align-items: center;
}
.sun-label-left { left: 0; }
.sun-label-right { right: 0; }
.sun-label-center {
  position: absolute; bottom: 80rpx; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
}
.sun-lbl-time { font-size: 26rpx; font-weight: 600; color: #333; }
.sun-lbl-text { font-size: 20rpx; color: #999; margin-top: 2rpx; }
.sun-lb-hint { font-size: 22rpx; color: #999; }

/* 分享按钮 */
.share-btn {
  margin-left: auto; display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 20rpx; border-radius: 24rpx;
  background: rgba(102,126,234,0.1);
}
.share-icon { font-size: 24rpx; }
.share-text { font-size: 22rpx; color: #667eea; font-weight: 500; }

/* ===== 导航栏 ===== */
.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(0,0,0,0.08); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.nav-content {
  display: flex; align-items: center; padding-left: 16rpx;
  box-sizing: border-box;
}

/* 城市标签栏 */
.city-tabs {
  flex: 1; display: flex; align-items: center; overflow-x: auto;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
}
.city-tabs::-webkit-scrollbar { display: none; }
.city-tab {
  flex-shrink: 0; padding: 8rpx 24rpx; margin-right: 12rpx;
  font-size: 26rpx; color: rgba(255,255,255,0.7); border-radius: 20rpx;
  background: rgba(255,255,255,0.1); white-space: nowrap;
  transition: all 0.25s;
}
.city-tab.active {
  background: rgba(255,255,255,0.25); color: #fff; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.city-tab-add {
  flex-shrink: 0; width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center;
  margin-left: 4rpx;
}
.add-icon { color: #fff; font-size: 30rpx; line-height: 1; }

/* 搜索按钮 */
.nav-search-btn {
  flex-shrink: 0; width: 64rpx; height: 64rpx; margin-left: 8rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: rgba(255,255,255,0.12);
}
.nav-search-icon { font-size: 28rpx; }

/* ===== 搜索面板 ===== */
.search-panel {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200;
}
.search-panel-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
}
.search-panel-content {
  position: relative; z-index: 1; background: #fff;
  border-radius: 0 0 32rpx 32rpx; padding-bottom: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  max-height: 80vh; overflow-y: auto;
}
.search-panel-bar {
  display: flex; align-items: center; padding: 16rpx 20rpx;
}
.search-input-wrap {
  flex: 1; display: flex; align-items: center; height: 72rpx;
  background: #f5f5f5; border-radius: 36rpx; padding: 0 28rpx;
}
.search-panel-input { flex: 1; font-size: 28rpx; color: #333; }
.search-panel-placeholder { color: #bbb; }
.search-cancel {
  margin-left: 20rpx; font-size: 28rpx; color: #667eea;
  flex-shrink: 0; padding: 0 8rpx;
}

/* 搜索建议 */
.search-suggestions { padding: 0 24rpx; }
.suggestion-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.suggestion-item:last-child { border-bottom: none; }
.suggestion-name { font-size: 28rpx; color: #333; font-weight: 500; }
.suggestion-detail { font-size: 22rpx; color: #bbb; }

/* 搜索历史 & 热门 */
.search-section-title {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 24rpx; color: #999; padding: 20rpx 24rpx 12rpx; font-weight: 600;
}
.clear-history { color: #667eea; font-weight: 400; }
.history-tags, .hot-cities {
  display: flex; flex-wrap: wrap; padding: 0 20rpx;
}
.history-tag, .hot-city {
  padding: 12rpx 28rpx; margin: 8rpx; font-size: 24rpx; color: #666;
  background: #f5f5f5; border-radius: 24rpx;
}
.hot-city { background: rgba(102,126,234,0.08); color: #667eea; }

/* ===== 滚动区 ===== */
.main-scroll {
  position: relative; z-index: 1; height: 100vh;
  box-sizing: border-box;
}

/* ===== 下拉刷新指示器 ===== */
.refresh-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 8rpx;
  gap: 12rpx;
}
.refresh-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.refresh-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 头部 ===== */
.header { text-align: center; color: #fff; padding: 60rpx 40rpx 40rpx; }
.city-name { font-size: 44rpx; font-weight: 700; letter-spacing: 2rpx; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); }
.update-time { font-size: 22rpx; color: rgba(255,255,255,0.6); margin-top: 6rpx; }
.greeting { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-bottom: 10rpx; }
.current-temp { display: flex; align-items: flex-start; justify-content: center; margin: 10rpx 0; }
.temp-num { font-size: 180rpx; font-weight: 200; line-height: 1; text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1); }
.temp-unit { font-size: 48rpx; font-weight: 300; margin-top: 20rpx; opacity: 0.8; }
.current-weather { display: flex; align-items: center; justify-content: center; gap: 12rpx; margin: 16rpx 0; }
.weather-icon-big { font-size: 40rpx; }
.weather-text { font-size: 32rpx; font-weight: 400; opacity: 0.9; }
.feels-like { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.pm-badge {
  display: inline-flex; align-items: center; padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border-radius: 32rpx; font-size: 22rpx; color: #fff; margin-top: 10rpx;
}
.pm-dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 10rpx; }

/* ===== 内容卡片 ===== */
.section { position: relative; z-index: 2; }
.glass-card {
  background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx; margin: 0 24rpx 20rpx; padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08); border: 1rpx solid rgba(255,255,255,0.5);
}
.card-title { font-size: 26rpx; font-weight: 600; color: #666; margin-bottom: 20rpx; display: flex; align-items: center; }
.card-title .icon { margin-right: 10rpx; font-size: 28rpx; }

/* 24小时 */
.hourly-scroll { white-space: nowrap; overflow: hidden; }
.hourly-list { display: flex; padding: 10rpx 0; }
.hourly-item {
  display: flex; flex-direction: column; align-items: center;
  min-width: 110rpx; padding: 16rpx 8rpx; border-radius: 20rpx; margin-right: 4rpx;
}
.hourly-item.current { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.3); }
.hourly-time { font-size: 22rpx; color: #999; margin-bottom: 12rpx; }
.hourly-item.current .hourly-time { color: rgba(255,255,255,0.8); }
.hourly-icon { font-size: 40rpx; margin-bottom: 12rpx; }
.hourly-temp { font-size: 28rpx; font-weight: 600; color: #333; }
.hourly-item.current .hourly-temp { color: #fff; }

/* 多天预报 */
.forecast-list { display: flex; flex-direction: column; }
.forecast-item {
  display: grid; grid-template-columns: 90rpx 50rpx 100rpx 1fr; align-items: center;
  padding: 18rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.forecast-item:last-child { border-bottom: none; }
.forecast-item.today { font-weight: 600; }
.day-name { font-size: 26rpx; color: #666; }
.forecast-item.today .day-name { color: #667eea; }
.day-icon { font-size: 32rpx; text-align: center; }
.day-weather { font-size: 22rpx; color: #aaa; text-align: center; }
.day-temp-bar { display: flex; align-items: center; }
.temp-bar { position: relative; width: 100%; height: 6rpx; background: rgba(0,0,0,0.06); border-radius: 3rpx; flex: 1; }
.temp-bar-fill { position: absolute; top: 0; height: 100%; border-radius: 3rpx; min-width: 20%; }
.temp-range-text { font-size: 22rpx; color: #999; margin-left: 12rpx; white-space: nowrap; }
.day-precip { margin-left: 8rpx; }
.precip-text { font-size: 20rpx; color: #42a5f5; }

/* 天气详情 */
.detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.detail-cell { display: flex; align-items: center; padding: 16rpx; border-radius: 16rpx; background: rgba(0,0,0,0.02); }
.detail-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.detail-label { font-size: 20rpx; color: #bbb; margin-bottom: 2rpx; display: block; width: 100%; }
.detail-value { font-size: 26rpx; font-weight: 600; color: #333; display: block; width: 100%; }

/* AQI */
.aqi-row { display: flex; align-items: center; }
.aqi-badge {
  width: 130rpx; height: 130rpx; border-radius: 24rpx; flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center; margin-right: 24rpx;
}
.aqi-val { font-size: 40rpx; font-weight: 700; color: #fff; }
.aqi-desc { font-size: 20rpx; color: rgba(255,255,255,0.9); }
.aqi-info { flex: 1; }
.aqi-detail-text { font-size: 22rpx; color: #999; margin-bottom: 12rpx; }
.aqi-bar-wrap { position: relative; height: 10rpx; border-radius: 5rpx; background: linear-gradient(to right, #00e400, #ffff00, #ff7e00, #ff0000, #99004c, #7e0023); margin-bottom: 8rpx; }
.aqi-bar-indicator {
  position: absolute; top: -4rpx; width: 18rpx; height: 18rpx; border-radius: 50%;
  background: #fff; border: 3rpx solid #333; transform: translateX(-50%);
}
.aqi-labels { display: flex; justify-content: space-between; font-size: 18rpx; color: #ccc; }

/* 污染物 */
.pollutants-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx;
  margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(0,0,0,0.04);
}
.pollutant-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 12rpx 0; border-radius: 12rpx; background: rgba(0,0,0,0.02);
}
.pollutant-name { font-size: 20rpx; color: #999; margin-bottom: 4rpx; }
.pollutant-value { font-size: 28rpx; font-weight: 600; }
.aqi-source { margin-top: 12rpx; text-align: right; }
.source-text { font-size: 20rpx; color: #bbb; }

/* 生活指数 */
.indices-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.index-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 8rpx; border-radius: 16rpx; background: rgba(0,0,0,0.02); text-align: center;
}
.index-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.index-name { font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.index-category { font-size: 24rpx; font-weight: 600; color: #333; margin-bottom: 4rpx; }
.index-text { font-size: 20rpx; color: #aaa; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

/* 底部 */
.footer { text-align: center; padding: 40rpx 0 160rpx; font-size: 22rpx; color: rgba(255,255,255,0.4); position: relative; z-index: 2; }

/* ===== 右下角悬浮按钮 ===== */
.fab {
  position: fixed; right: 32rpx; bottom: 120rpx; z-index: 50;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12); border: 1rpx solid rgba(255,255,255,0.3);
}
.fab-icon { font-size: 40rpx; }
