<!-- 易观风云 v2.1 -->
<view class="page {{isIPhoneX ? 'iphonex-padding' : ''}}">

  <!-- 背景 -->
  <view class="page-bg" style="{{bgStyle}}"></view>

  <!-- 天气动画效果 -->
  <view class="weather-effects {{weatherEffectClass}}">
    <!-- 雨滴 -->
    <block wx:if="{{weatherEffectClass === 'effect-rain' || weatherEffectClass === 'effect-heavy-rain'}}">
      <view class="rain-drop" style="--delay: 0s; --left: 10%; --dur: 0.8s"></view>
      <view class="rain-drop" style="--delay: 0.15s; --left: 20%; --dur: 0.7s"></view>
      <view class="rain-drop" style="--delay: 0.3s; --left: 30%; --dur: 0.9s"></view>
      <view class="rain-drop" style="--delay: 0.1s; --left: 40%; --dur: 0.75s"></view>
      <view class="rain-drop" style="--delay: 0.25s; --left: 50%; --dur: 0.85s"></view>
      <view class="rain-drop" style="--delay: 0.4s; --left: 60%; --dur: 0.7s"></view>
      <view class="rain-drop" style="--delay: 0.05s; --left: 70%; --dur: 0.8s"></view>
      <view class="rain-drop" style="--delay: 0.2s; --left: 80%; --dur: 0.9s"></view>
      <view class="rain-drop" style="--delay: 0.35s; --left: 90%; --dur: 0.75s"></view>
      <view class="rain-drop" style="--delay: 0.12s; --left: 15%; --dur: 0.82s"></view>
      <view class="rain-drop" style="--delay: 0.28s; --left: 35%; --dur: 0.68s"></view>
      <view class="rain-drop" style="--delay: 0.18s; --left: 55%; --dur: 0.88s"></view>
      <view class="rain-drop" style="--delay: 0.32s; --left: 75%; --dur: 0.72s"></view>
      <view class="rain-drop" style="--delay: 0.08s; --left: 45%; --dur: 0.78s"></view>
      <view class="rain-drop" style="--delay: 0.22s; --left: 65%; --dur: 0.86s"></view>
    </block>
    <!-- 雪花 -->
    <block wx:if="{{weatherEffectClass === 'effect-snow'}}">
      <view class="snowflake" style="--delay: 0s; --left: 10%; --dur: 4s; --size: 6px"></view>
      <view class="snowflake" style="--delay: 0.8s; --left: 25%; --dur: 5s; --size: 8px"></view>
      <view class="snowflake" style="--delay: 1.5s; --left: 40%; --dur: 4.5s; --size: 5px"></view>
      <view class="snowflake" style="--delay: 0.3s; --left: 55%; --dur: 5.5s; --size: 7px"></view>
      <view class="snowflake" style="--delay: 1.2s; --left: 70%; --dur: 4.2s; --size: 6px"></view>
      <view class="snowflake" style="--delay: 2s; --left: 85%; --dur: 5.2s; --size: 8px"></view>
      <view class="snowflake" style="--delay: 0.5s; --left: 15%; --dur: 4.8s; --size: 5px"></view>
      <view class="snowflake" style="--delay: 1.8s; --left: 35%; --dur: 5.1s; --size: 7px"></view>
      <view class="snowflake" style="--delay: 1s; --left: 60%; --dur: 4.3s; --size: 6px"></view>
      <view class="snowflake" style="--delay: 2.3s; --left: 80%; --dur: 5.4s; --size: 5px"></view>
      <view class="snowflake" style="--delay: 0.6s; --left: 48%; --dur: 4.6s; --size: 8px"></view>
      <view class="snowflake" style="--delay: 1.4s; --left: 92%; --dur: 5s; --size: 6px"></view>
    </block>
    <!-- 雾 -->
    <block wx:if="{{weatherEffectClass === 'effect-fog'}}">
      <view class="fog-layer fog-1"></view>
      <view class="fog-layer fog-2"></view>
      <view class="fog-layer fog-3"></view>
    </block>
    <!-- 雷暴 -->
    <block wx:if="{{weatherEffectClass === 'effect-thunder'}}">
      <view class="lightning-flash"></view>
      <view class="rain-drop" style="--delay: 0s; --left: 10%; --dur: 0.6s"></view>
      <view class="rain-drop" style="--delay: 0.1s; --left: 25%; --dur: 0.55s"></view>
      <view class="rain-drop" style="--delay: 0.2s; --left: 40%; --dur: 0.65s"></view>
      <view class="rain-drop" style="--delay: 0.05s; --left: 55%; --dur: 0.58s"></view>
      <view class="rain-drop" style="--delay: 0.15s; --left: 70%; --dur: 0.62s"></view>
      <view class="rain-drop" style="--delay: 0.25s; --left: 85%; --dur: 0.55s"></view>
      <view class="rain-drop" style="--delay: 0.08s; --left: 30%; --dur: 0.63s"></view>
      <view class="rain-drop" style="--delay: 0.18s; --left: 60%; --dur: 0.57s"></view>
    </block>
  </view>

  <!-- 骨架屏 -->
  <skeleton wx:if="{{loading && !refreshing}}"></skeleton>

  <!-- 正式内容（加载完成或正在刷新时保留显示） -->
  <block wx:if="{{!loading || refreshing}}">

    <!-- 顶部导航栏：高度 = 状态栏 + 内容区，右侧留出胶囊按钮空间 -->
    <view class="nav-bar" style="height: {{navBarTotalHeight}}px; padding-top: {{statusBarHeight}}px">
      <view class="nav-content" style="height: {{navBarContentHeight}}px; padding-right: {{navContentPaddingRight}}px">
        <!-- 城市标签栏 -->
        <view class="city-tabs">
          <view class="city-tab {{activeCityIndex === index ? 'active' : ''}}" 
            wx:for="{{savedCities}}" wx:key="index"
            catchtap="switchCity" data-index="{{index}}"
            bindlongpress="onCityLongPress" data-city-index="{{index}}">
            {{item.name}}
          </view>
          <view class="city-tab-add" catchtap="goCityChoose">
            <text class="add-icon">+</text>
          </view>
        </view>
        <!-- 搜索按钮 -->
        <view class="nav-search-btn" catchtap="showSearchPanel">
          <text class="nav-search-icon">🔍</text>
        </view>
      </view>
    </view>

    <!-- 搜索面板（覆盖层） -->
    <view class="search-panel" wx:if="{{searchPanelShow}}">
      <view class="search-panel-bg" catchtap="hideSearchPanel"></view>
      <view class="search-panel-content" style="padding-top: {{navBarTotalHeight}}px">
        <view class="search-panel-bar">
          <view class="search-input-wrap">
            <input class="search-panel-input" placeholder="搜索城市名称" 
              placeholder-class="search-panel-placeholder"
              confirm-type="search" focus="{{searchPanelShow}}"
              value="{{searchText}}" bindconfirm="onSearchConfirm"
              bindinput="onSearchInput" />
          </view>
          <text class="search-cancel" catchtap="hideSearchPanel">取消</text>
        </view>
        <!-- 搜索建议 -->
        <view class="search-suggestions" wx:if="{{searchSuggestions.length > 0}}">
          <view class="suggestion-item" wx:for="{{searchSuggestions}}" wx:key="name"
            catchtap="onSuggestionTap" data-name="{{item.name}}">
            <text class="suggestion-name">{{item.name}}</text>
            <text class="suggestion-detail">{{item.admin1}} {{item.admin2}}</text>
          </view>
        </view>
        <!-- 搜索历史 -->
        <view class="search-history" wx:if="{{searchSuggestions.length === 0 && searchHistory.length > 0}}">
          <view class="search-section-title">
            <text>搜索历史</text>
            <text class="clear-history" catchtap="clearSearchHistory">清除</text>
          </view>
          <view class="history-tags">
            <view class="history-tag" wx:for="{{searchHistory}}" wx:key="*this"
              catchtap="onSuggestionTap" data-name="{{item}}">
              {{item}}
            </view>
          </view>
        </view>
        <!-- 热门城市 -->
        <view class="search-hot" wx:if="{{searchSuggestions.length === 0}}">
          <view class="search-section-title"><text>热门城市</text></view>
          <view class="hot-cities">
            <view class="hot-city" wx:for="{{hotCities}}" wx:key="*this"
              catchtap="onSuggestionTap" data-name="{{item}}">
              {{item}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <scroll-view
      scroll-y
      class="main-scroll"
      style="padding-top: {{navBarTotalHeight}}px"
      enable-back-to-top
      refresher-enabled
      refresher-triggered="{{refreshing}}"
      refresher-background="transparent"
      refresher-default-style="none"
      refresher-threshold="80"
      bindrefresherrefresh="onPullDownRefresh"
    >
      <!-- 自定义下拉刷新指示器 -->
      <view class="refresh-indicator" wx:if="{{refreshing}}">
        <view class="refresh-spinner"></view>
        <text class="refresh-text">正在刷新...</text>
      </view>

      <!-- ====== 头部：城市 + 温度 ====== -->
      <view class="header fade-in-up">
        <view class="header-info">
          <view class="city-name">{{cityName}}</view>
          <view class="update-time">{{updateTime}} 更新</view>
        </view>
        <view class="greeting">{{greeting}}</view>
        <view class="current-temp">
          <text class="temp-num">{{currentTemp}}</text>
          <text class="temp-unit">°C</text>
        </view>
        <view class="current-weather">
          <text class="weather-icon-big">{{currentIcon}}</text>
          <text class="weather-text">{{currentWeather}}</text>
          <text class="feels-like">体感 {{feelsLike}}°</text>
        </view>
        <view class="pm-badge" wx:if="{{pm.val}}">
          <view class="pm-dot" style="background: {{pm.color}}"></view>
          <text>{{pm.desc}} PM2.5 {{pm.val}}</text>
        </view>
      </view>

      <!-- ====== 24小时预报 ====== -->
      <view class="section fade-in-up" wx:if="{{hourlyData.length > 0}}">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">🕐</text>
            <text>逐时预报</text>
          </view>
          <scroll-view scroll-x class="hourly-scroll" enable-flex>
            <view class="hourly-list">
              <view class="hourly-item {{index === 0 ? 'current' : ''}}" wx:for="{{hourlyData}}" wx:key="index">
                <view class="hourly-time">{{item.time}}</view>
                <view class="hourly-icon">{{item.icon}}</view>
                <view class="hourly-temp">{{item.temp}}°</view>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <!-- ====== 7天预报 ====== -->
      <view class="section fade-in-up" wx:if="{{dailyData.length > 0}}">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">📅</text>
            <text>{{dailyData.length}}天预报</text>
          </view>
          <view class="forecast-list">
            <view class="forecast-item {{index === 0 ? 'today' : ''}}" wx:for="{{dailyData}}" wx:key="index">
              <view class="day-name">{{item.weekDay}}</view>
              <view class="day-icon">{{item.icon}}</view>
              <view class="day-weather">{{item.weather}}</view>
              <view class="day-temp-bar">
                <view class="temp-bar">
                  <view class="temp-bar-fill" style="left: {{item.tempLeft}}%; width: {{item.tempWidth}}%; background: linear-gradient(90deg, {{item.tempColor}})"></view>
                </view>
                <view class="temp-range-text">{{item.low}}° / {{item.high}}°</view>
              </view>
              <view class="day-precip" wx:if="{{item.precipProb > 0}}">
                <text class="precip-text">💧{{item.precipProb}}%</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ====== 日出日落 ====== -->
      <view class="section fade-in-up">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">🌅</text>
            <text>日出日落</text>
          </view>
          <view class="sun-arc-wrap">
            <view class="sun-arc">
              <!-- 弧线背景 -->
              <view class="sun-arc-path"></view>
              <!-- 弧线进度 -->
              <view class="sun-arc-fill" style="clip-path: polygon(0 0, {{sunProgressPct}}% 0, {{sunProgressPct}}% 100%, 0 100%)"></view>
              <!-- 太阳 -->
              <view class="sun-arc-dot" style="left: {{sunX}}px; bottom: {{sunY}}px">
                <text class="sun-dot-icon">☀️</text>
              </view>
              <!-- 地平线 -->
              <view class="sun-horizon"></view>
              <!-- 标签 -->
              <view class="sun-label-left">
                <text class="sun-lbl-time">{{sunrise}}</text>
                <text class="sun-lbl-text">日出</text>
              </view>
              <view class="sun-label-right">
                <text class="sun-lbl-time">{{sunset}}</text>
                <text class="sun-lbl-text">日落</text>
              </view>
              <view class="sun-label-center" wx:if="{{sunProgress > 0 && sunProgress < 1}}">
                <text class="sun-lb-hint">白天还剩 {{daylightRemaining}}</text>
              </view>
              <view class="sun-label-center" wx:elif="{{sunProgress >= 1}}">
                <text class="sun-lb-hint">已日落 · {{nextSunEvent}}</text>
              </view>
              <view class="sun-label-center" wx:else>
                <text class="sun-lb-hint">未日出 · {{nextSunEvent}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ====== 天气详情 ====== -->
      <view class="section fade-in-up">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">🌡️</text>
            <text>天气详情</text>
            <view class="share-btn" catchtap="onShareCard">
              <text class="share-icon">📤</text>
              <text class="share-text">分享</text>
            </view>
          </view>
          <view class="detail-grid">
            <view class="detail-cell">
              <view class="detail-icon">🌡️</view>
              <view class="detail-label">体感温度</view>
              <view class="detail-value">{{feelsLike}}°</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">💧</view>
              <view class="detail-label">相对湿度</view>
              <view class="detail-value">{{humidity}}%</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">💨</view>
              <view class="detail-label">风速</view>
              <view class="detail-value">{{windSpeed}} km/h</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">🧭</view>
              <view class="detail-label">风向</view>
              <view class="detail-value">{{windDir}}</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">☀️</view>
              <view class="detail-label">紫外线</view>
              <view class="detail-value">{{uvIndex}}</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">📊</view>
              <view class="detail-label">气压</view>
              <view class="detail-value">{{pressure}} hPa</view>
            </view>
            <view class="detail-cell">
              <view class="detail-icon">🌧️</view>
              <view class="detail-label">降水概率</view>
              <view class="detail-value">{{precipProb}}%</view>
            </view>
          </view>
        </view>
      </view>

      <!-- ====== 空气质量 ====== -->
      <view class="section fade-in-up">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">🌬️</text>
            <text>空气质量</text>
          </view>
          <view class="aqi-row">
            <view class="aqi-badge" style="background: {{pm.color}}">
              <view class="aqi-val">{{pm.val || '--'}}</view>
              <view class="aqi-desc">{{pm.desc || '--'}}</view>
            </view>
            <view class="aqi-info">
              <view class="aqi-detail-text">{{pm.detail || ''}}</view>
              <view class="aqi-bar-wrap">
                <view class="aqi-bar-bg"></view>
                <view class="aqi-bar-indicator" style="left: {{pm.val ? Math.min(pm.val / 5, 100) : 0}}%"></view>
              </view>
              <view class="aqi-labels">
                <text>优</text><text>良</text><text>轻度</text><text>中度</text><text>重度</text><text>严重</text>
              </view>
            </view>
          </view>
          <view class="pollutants-grid" wx:if="{{aqiDetail && aqiDetail.pollutants}}">
            <view class="pollutant-item" wx:for="{{aqiDetail.pollutants}}" wx:key="key">
              <view class="pollutant-name">{{item.key}}</view>
              <view class="pollutant-value" style="color: {{item.color}}">{{item.value}}</view>
            </view>
          </view>
          <view class="aqi-source" wx:if="{{aqiDetail && aqiDetail.station}}">
            <text class="source-text">📍 {{aqiDetail.station}}</text>
          </view>
        </view>
      </view>

      <!-- ====== 生活指数 ====== -->
      <view class="section fade-in-up" wx:if="{{lifeIndices.length > 0}}">
        <view class="glass-card">
          <view class="card-title">
            <text class="icon">💡</text>
            <text>生活指数</text>
          </view>
          <view class="indices-grid">
            <view class="index-item" wx:for="{{lifeIndices}}" wx:key="type">
              <view class="index-icon">{{item.icon}}</view>
              <view class="index-name">{{item.name}}</view>
              <view class="index-category">{{item.category}}</view>
              <view class="index-text">{{item.text}}</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部 -->
      <view class="footer">
        <text>易观风云 · Open-Meteo 数据支持</text>
      </view>

    </scroll-view>

    <!-- 右下角悬浮按钮 -->
    <view class="fab" catchtap="goSetting">
      <text class="fab-icon">⚙️</text>
    </view>

  </block>
</view>
